    {
      "name": "ISO Parse (Main Tests - HEX Format Only)",
      "item": [
        {
          "name": "ISO Parse - Raw HEX (3 known fields)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{isoHexKnownOnly}}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/iso/limit/{{pan}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "iso",
                "limit",
                "{{pan}}"
              ]
            }
          }
        },
        {
          "name": "ISO Parse - Raw HEX (mixed known + extra fields)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/plain"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{isoHexMixedFields}}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/iso/limit/{{pan}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "iso",
                "limit",
                "{{pan}}"
              ]
            },
            "description": "Use full ISO HEX payload format. XML inside DE127 can contain mixed order fields. Known fields are mapped to core tables; unknown fields go to limit_extra_data. If XML changes, regenerate full HEX using root helper IsoHexGenerator.java."
          }
        },
        {
          "name": "ISO Parse - JSON Wrapper (optional)",
          "request": {
